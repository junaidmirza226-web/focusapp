        android:fillColor="#FFFFFF"
        android:strokeColor="#000000"
        android:strokeWidth="5"
        android:fillAlpha="0"
        android:pathData="M44,48 L44,38 Q44,28 54,28 Q64,28 64,38 L64,48" />

