<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="64dp" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="Focus Breached"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/overlay_lock_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:textColor="#9CA3AF"
            android:textSize="17sp"
            android:gravity="center"
            android:text="You've run out of time on this app." />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── Strict mode banner (shown when strict mode is ON) ──────── -->
        <TextView
            android:id="@+id/overlay_strict_mode_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:textColor="#EF4444"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="🔒 Strict Mode Active\nNo unlock options available."
            android:visibility="gone" />

        <Button
            android:id="@+id/overlay_btn_pay_fine"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FFFFFF"
            android:text="Pay the fine to unlock"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="Close this app or press Home to exit."
            android:textColor="#555555"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>
</FrameLayout>
