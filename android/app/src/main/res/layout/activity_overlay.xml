<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Main lock screen content ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/lock_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <Space
            android:layout_width="match_parent"
            android:layout_height="64dp" />

        <!-- Lock icon -->
        <ImageView
            android:id="@+id/lock_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:id="@+id/lock_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="Access Blocked"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <!-- App name / message -->
        <TextView
            android:id="@+id/lock_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:gravity="center"
            android:text="You've reached your daily limit." />

        <TextView
            android:id="@+id/block_reason_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="#111111"
            android:textColor="#F59E0B"
            android:textStyle="bold"
            android:textSize="12sp"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Escalation notice (hidden by default) -->
        <TextView
            android:id="@+id/escalation_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1A1A1A"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:textColor="#F59E0B"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone" />

        <!-- ── Payment section ─────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/payment_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_pay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#FFFFFF"
                android:text="Pay $1.00 — 15 min"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_extended_unlock"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#1A1A1A"
                android:text="Pay $5.00 — 1 hour"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_daily_pass"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#1A1A1A"
                android:text="Pay $20.00 — Full day"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- ── Strict mode banner (shown instead of payment buttons) ──────── -->
        <TextView
            android:id="@+id/strict_mode_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:textColor="#EF4444"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="🔒 Strict Mode Active\nPay-to-unlock is disabled."
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Close / go home button -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#111111"
            android:text="Close App"
            android:textAllCaps="false"
            android:textColor="#9CA3AF"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="FOCUSFINE • STAY DISCIPLINED"
            android:textColor="#374151"
            android:textSize="10sp"
            android:letterSpacing="0.12" />

    </LinearLayout>

    <!-- ── Success screen (shown after payment, auto-dismisses) ─────────── -->
    <LinearLayout
        android:id="@+id/success_section"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="#22C55E"
            android:textSize="72sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Unlocked!"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/success_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
